# Stripe Secret Key (haal op uit https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXX

# Stripe Price IDs — maak producten/prijzen aan in Stripe Dashboard
# OF laat de server dynamic line_items gebruiken (standaard gedrag als deze leeg zijn)
STRIPE_PRICE_PAKKET_1=
STRIPE_PRICE_PAKKET_5=
STRIPE_PRICE_PAKKET_10=

# E-Book Stripe Price IDs (optioneel — server gebruikt dynamic line_items als deze leeg zijn)
STRIPE_PRICE_EBOOK_1=
STRIPE_PRICE_EBOOK_2=
STRIPE_PRICE_EBOOK_3=

# Stripe Webhook Secret (optioneel maar aanbevolen voor productie)
STRIPE_WEBHOOK_SECRET=

# Server
PORT=3000
BASE_URL=http://localhost:3000

# Spoonacular (gratis tier: https://spoonacular.com/food-api/console)
SPOONACULAR_API_KEY=

# Amazon Affiliate (optioneel — voor commissie tracking)
AMAZON_ASSOCIATE_TAG=
